# LLM 配置 (DeepSeek V4-Flash 推荐，便宜好用)
LLM_MODEL=deepseek-chat
LLM_API_KEY=your-deepseek-api-key
LLM_BASE_URL=https://api.deepseek.com/v1

# Embedding 模型 (本地运行，无需 API Key)
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ASR (达摩院/阿里云实时语音)
ASR_APP_KEY=your-app-key
ASR_ACCESS_KEY_ID=your-access-key-id
ASR_ACCESS_KEY_SECRET=your-access-key-secret

# OCR (PaddleOCR 本地运行，免费，无需配置)

# Milvus 向量数据库
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Database
DATABASE_URL=sqlite:///./smart_notes.db
